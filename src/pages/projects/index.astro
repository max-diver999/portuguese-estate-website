---
export const prerender = true;
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProjectCard from '../../components/ProjectCard.astro';
import { formatUsd } from '../../lib/cardImage';

const projects = (await getCollection('projects'))
  .filter((p) => !p.data.noindex)
  .sort((a, b) => (a.data.priceFromUsd ?? 0) - (b.data.priceFromUsd ?? 0));

const priced = projects.map((p) => p.data.priceFromUsd).filter((v): v is number => !!v && v > 0);
const minPrice = priced.length ? Math.min(...priced) : 150000;
---
<BaseLayout
  title="Mexico Real Estate Projects"
  description="Independent project reviews for foreign buyers — Riviera Maya, Los Cabos, and Puerto Vallarta developments with prices and due diligence notes."
>
  <section class="site-container py-14 md:py-20">
    <header class="max-w-2xl mb-12">
      <h1 class="text-3xl">Project reviews</h1>
      <p class="text-lg text-[var(--color-muted)] mt-3">
        <strong>{projects.length} projects</strong> with editorial analysis — from <strong>{formatUsd(minPrice) || '$150K'}</strong>, photos, and due diligence notes. Not developer marketing.
      </p>
    </header>
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
      {projects.map((project) => (
        <ProjectCard
          href={`/projects/${project.id}/`}
          title={project.data.title}
          description={project.data.description}
          image={project.data.heroImage}
          area={project.data.area}
          developer={project.data.developer}
          propertyType={project.data.propertyType}
          status={project.data.status}
          priceFromUsd={project.data.priceFromUsd}
        />
      ))}
    </div>
  </section>
</BaseLayout>
