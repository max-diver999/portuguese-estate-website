---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { SITE } from '../../data/site';
---
<BaseLayout
  title="About Portuguese Estate"
  description="Portuguese Estate is an independent editorial resource on UAE and Spain property investment — not a developer or listing portal."
>
  <section class="site-container py-12 md:py-16 max-w-3xl">
    <h1 class="mb-6">About {SITE.name}</h1>
    <div class="prose">
      <p>
        {SITE.name} publishes research-first guides for foreign buyers evaluating Riviera Maya, Los Cabos, and wider Gulf markets.
        We are <strong>not</strong> a developer, not a property portal, and not a substitute for licensed legal or tax advice.
      </p>
      <h2>What we do</h2>
      <ul>
        <li>Explain ownership rules, fee stacks, and fideicomiso thresholds in plain English</li>
        <li>Compare markets and product types (off-plan vs ready, yield vs capital growth)</li>
        <li>Connect serious enquiries to <strong>AMPI-licensed partners</strong> when you request a shortlist</li>
      </ul>
      <h2>What we don't do</h2>
      <ul>
        <li>Push specific developer inventory or take undisclosed referral fees without disclosure</li>
        <li>Guarantee yields, capital appreciation, or visa outcomes</li>
        <li>Provide personalised financial, legal, or tax advice</li>
      </ul>
      <p>
        Questions? Email <a href={`mailto:${SITE.email}`}>{SITE.email}</a> or read our
        <a href="/methodology/">methodology</a>.
      </p>
    </div>
  </section>
</BaseLayout>
