---
import { SITE } from '../data/site';

const nav = [
  { label: 'Guides', href: '/guides/' },
  { label: 'Projects', href: '/projects/' },
  { label: 'Areas', href: '/areas/' },
  { label: 'Compare', href: '/compare/' },
  { label: 'About', href: '/about/' },
  { label: 'Contact', href: '/contact/' },
];
---
<header class="sticky top-0 z-50 border-b border-[var(--color-border)] bg-[rgba(255,255,255,0.9)] backdrop-blur-md">
  <div class="site-container flex items-center justify-between gap-4 py-4">
    <a href="/" class="flex items-center gap-2 no-underline">
      <img src="/favicon.svg?v=3" alt="" width="32" height="32" class="rounded-lg" />
      <span class="text-lg font-semibold text-[var(--color-ink)]">{SITE.name}</span>
    </a>
    <nav class="hidden md:flex items-center gap-6 text-sm font-medium">
      {nav.map((item) => (
        <a href={item.href} class="text-[var(--color-muted)] hover:text-[var(--color-ink)] no-underline">{item.label}</a>
      ))}
    </nav>
    <a href="/get-shortlist/" class="btn-primary text-sm px-4 py-2 shrink-0">Free shortlist</a>
  </div>
</header>
