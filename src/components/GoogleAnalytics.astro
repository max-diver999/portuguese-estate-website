---
/** GA4 — set PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX in Vercel / .env */
const measurementId = import.meta.env.PUBLIC_GA_MEASUREMENT_ID as string | undefined;
---
{measurementId && (
  <>
    <script async src={`https://www.googletagmanager.com/gtag/js?id=${measurementId}`}></script>
    <script define:vars={{ measurementId }}>
      window.dataLayer = window.dataLayer || [];
      function gtag() {
        dataLayer.push(arguments);
      }
      window.gtag = window.gtag || gtag;
      gtag('js', new Date());
      gtag('config', measurementId, {
        send_page_view: true,
        anonymize_ip: true,
      });

      window.investGulfTrack = function investGulfTrack(eventName, params = {}) {
        const payload = {
          page_location: window.location.href,
          page_path: window.location.pathname,
          transport_type: 'beacon',
          ...params,
        };
        if (typeof window.gtag === 'function') {
          window.gtag('event', eventName, payload);
        }
      };
    </script>
  </>
)}
