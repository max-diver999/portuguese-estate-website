---
import ContentCard from './ContentCard.astro';
import { formatAreaLabel, formatProjectPrice } from '../lib/cardImage';

interface Props {
  href: string;
  title: string;
  description?: string;
  image?: string;
  area?: string;
  developer?: string;
  propertyType?: string;
  status?: string;
  priceFromEUR?: number;
  priceFromUsd?: number;
}

const {
  href,
  title,
  description,
  image,
  area,
  developer,
  propertyType,
  status,
  priceFromEUR,
  priceFromUsd,
} = Astro.props;

const badges = [
  propertyType ? propertyType.replace(/-/g, ' ') : '',
  status === 'off-plan' ? 'Off-plan' : status === 'completed' ? 'Completed' : '',
  formatAreaLabel(area),
].filter(Boolean);

const price = formatProjectPrice(priceFromEUR, priceFromUsd);
const meta = [price && `From ${price}`, developer].filter(Boolean).join(' · ');
---

<ContentCard
  href={href}
  title={title}
  description={description}
  image={image}
  badges={badges}
  meta={meta}
  metaAccent={!!price}
  placeholder="🏢"
/>
