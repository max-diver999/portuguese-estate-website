---
import { SITE } from '../data/site';
const year = new Date().getFullYear();
---
<footer class="mt-16 border-t border-[var(--color-border)] bg-[var(--color-ink)] text-[#d6d3d1]">
  <div class="site-container py-12 grid gap-8 md:grid-cols-3 text-sm">
    <div>
      <p class="text-lg font-semibold text-white mb-2">{SITE.name}</p>
      <p class="leading-relaxed">{SITE.tagline}</p>
    </div>
    <div>
      <p class="font-semibold text-white mb-3">Explore</p>
      <ul class="space-y-2">
        <li><a href="/guides/" class="text-[#d6d3d1] hover:text-white no-underline">Guides</a></li>
        <li><a href="/compare/" class="text-[#d6d3d1] hover:text-white no-underline">Market comparisons</a></li>
        <li><a href="/methodology/" class="text-[#d6d3d1] hover:text-white no-underline">Methodology</a></li>
      </ul>
    </div>
    <div>
      <p class="font-semibold text-white mb-3">Legal</p>
      <ul class="space-y-2">
        <li><a href="/privacy-policy/" class="text-[#d6d3d1] hover:text-white no-underline">Privacy</a></li>
        <li><a href="/terms/" class="text-[#d6d3d1] hover:text-white no-underline">Terms</a></li>
        <li><a href={`mailto:${SITE.email}`} class="text-[#d6d3d1] hover:text-white no-underline">{SITE.email}</a></li>
      </ul>
    </div>
  </div>
  <div class="site-container py-4 border-t border-white/10 text-xs text-[#a8a29e]">
    © {year} {SITE.name}. Independent research — not financial or legal advice. Verify all figures with licensed professionals.
  </div>
</footer>
