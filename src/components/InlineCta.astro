---
import { SITE } from '../data/site';

interface Props {
  headline?: string;
  subtext?: string;
  buttonText?: string;
  buttonHref?: string;
  variant?: 'teal' | 'gold' | 'sand';
  ctaId?: string;
  showWhatsapp?: boolean;
  whatsappMessage?: string;
}

const {
  headline = 'Need a Portugal property shortlist?',
  subtext = 'Independent research — Lisbon, Algarve, Porto. Reply within one business day.',
  buttonText = 'Get free shortlist',
  buttonHref = '#lead-form',
  variant = 'teal',
  ctaId = 'inline_cta',
  showWhatsapp = true,
  whatsappMessage = "Hi Portuguese Estate! I read your Portugal property guide and I'd like a shortlist matched to my budget.",
} = Astro.props;

const variants = {
  teal: 'bg-gradient-to-r from-[var(--color-brand)] to-[#3d7a62] text-white',
  gold: 'bg-gradient-to-r from-[#b8860b] to-[#9a7209] text-white',
  sand: 'bg-[var(--color-surface)] text-[var(--color-ink)] border border-[var(--color-border)]',
};
const btnVariants = {
  teal: 'bg-white text-[var(--color-brand)] hover:bg-[var(--color-surface)]',
  gold: 'bg-white text-[#9a7209] hover:bg-[var(--color-surface)]',
  sand: 'btn-primary',
};

const waHref = `${SITE.whatsapp}?text=${encodeURIComponent(whatsappMessage)}`;
---
<div class={`rounded-xl p-6 my-8 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4 ${variants[variant]}`}>
  <div class="flex-1">
    <p class="font-semibold text-lg leading-snug">{headline}</p>
    {subtext && <p class="text-sm opacity-90 mt-1">{subtext}</p>}
  </div>
  <div class="flex flex-wrap items-center gap-2 flex-shrink-0">
    <a
      href={buttonHref}
      class={`inline-block px-5 py-2.5 rounded-lg font-medium text-sm whitespace-nowrap transition-colors no-underline ${variant === 'sand' ? 'btn-primary' : btnVariants[variant]}`}
      data-cta={`${ctaId}_primary`}
    >
      {buttonText}
    </a>
    {showWhatsapp && (
      <a
        href={waHref}
        target="_blank"
        rel="noopener"
        class="inline-flex items-center gap-1.5 px-4 py-2.5 rounded-lg font-medium text-sm whitespace-nowrap text-white no-underline transition-colors"
        style="background:#25D366;"
        data-cta={`${ctaId}_whatsapp`}
        aria-label="Message Portuguese Estate on WhatsApp"
      >
        <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
        WhatsApp
      </a>
    )}
  </div>
</div>
